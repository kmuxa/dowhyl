{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "gateway": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Gateway (LiteLLM)",
      "options": {
        "baseURL": "http://localhost:4000/v1",
        "apiKey": "{env:GATEWAY_KEY}"
      },
      "models": {
        "frontier": {
          "name": "frontier (Opus/GPT-5.5 — brutal 5%)"
        },
        "smart": {
          "name": "smart (Sonnet 5 / Qwen3-Coder / DeepSeek V4)"
        },
        "mid": {
          "name": "mid (gpt-oss-120b / DeepSeek Flash — free)"
        },
        "long": {
          "name": "long (Gemini 3 Flash 1M ctx — free)"
        },
        "cheap": {
          "name": "cheap (Flash-Lite / Llama-8B — free)"
        },
        "overflow": {
          "name": "overflow (DeepSeek V4 Flash — cheapest paid fallback)"
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  },
  "agent": {
    "plan": {
      "model": "gateway/smart",
      "mode": "primary"
    },
    "build": {
      "model": "gateway/mid",
      "mode": "primary"
    }
  }
}
