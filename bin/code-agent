#!/usr/bin/env bash
# ============================================================================
#  code-agent — launch a coding agent IN THE CURRENT DIRECTORY with a
#  permission mode. No worktrees, no containers: the agent's own permission
#  system is the control surface, and git is your undo net.
#
#  usage:   code-agent [plan|edit|auto|full]        (default: edit)
#
#    plan   read-only deep-dive: research the codebase, produce a plan.
#           Zero file changes (edits are denied/blocked by the agent).
#    edit   makes changes, asking before each edit / command is applied.
#    auto   applies edits freely; asks only before risky actions
#           (rm, sudo, git push, chmod, publishes…).
#    full   no prompts at all. Reserve for committed work / branches.
#
#  cockpit: AGENT=opencode|claude|codex   (default opencode)
#  extras:  SAFE=1 (drop China-hosted primary), BACKEND=gateway (claude only)
#
#  Mode → native mechanism:
#    opencode: permission overlay written to var/ + plan agent
#    claude:   --permission-mode plan|default|acceptEdits · full = --dangerously-skip-permissions
#    codex:    --sandbox read-only · defaults · --full-auto · --dangerously-bypass-approvals-and-sandbox
#  (flag names track current agent CLIs — if one errors, check that agent's docs)
# ============================================================================
set -euo pipefail

KIT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
AGENT="${AGENT:-opencode}"
MODE="${1:-edit}"
case "$MODE" in
  plan|edit|auto|full) ;;
  *) echo "usage: code-agent [plan|edit|auto|full]   (AGENT=opencode|claude|codex)"; exit 1 ;;
esac

# ---- primary + gateway key ---------------------------------------------------
[[ -f "$KIT_DIR/config/primary.env" ]] && source "$KIT_DIR/config/primary.env"
if [[ "${ANTHROPIC_AUTH_TOKEN:-}" == *paste-your* ]]; then
  unset ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN ANTHROPIC_MODEL
fi
if [[ "${SAFE:-}" == "1" ]]; then
  unset ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN ANTHROPIC_MODEL
  echo "→ SAFE mode: primary disabled; use no-train lanes (frontier / NVIDIA) only"
fi
[[ -f "$KIT_DIR/.env" ]] && export GATEWAY_KEY="$(grep -E '^GATEWAY_KEY=' "$KIT_DIR/.env" | cut -d= -f2-)"

# ---- git awareness (your undo net) ------------------------------------------
if git rev-parse --show-toplevel >/dev/null 2>&1; then
  BRANCH="$(git branch --show-current 2>/dev/null || echo '?')"
  echo "→ mode: $MODE · agent: $AGENT · dir: $PWD (branch: ${BRANCH:-detached})"
  if [[ -n "$(git status --porcelain 2>/dev/null | head -1)" && "$MODE" != "plan" ]]; then
    echo "⚠ uncommitted changes present — the agent edits this directory directly; consider committing or branching first"
  fi
else
  echo "→ mode: $MODE · agent: $AGENT · dir: $PWD"
  echo "⚠ not a git repo — there is NO undo net here"
fi
if [[ "$MODE" == "full" ]]; then
  echo "🔓 FULL ACCESS: no permission prompts. The agent can run anything, as you, here."
  echo "   Make sure this work is committed (or on a branch) before continuing."
fi

# ---- cockpit + mode → command ------------------------------------------------
case "$AGENT" in
  opencode)
    command -v opencode >/dev/null || { echo "install OpenCode first:  brew install sst/tap/opencode"; exit 1; }
    case "$MODE" in
      plan) PERM='{"edit":"deny","bash":"ask","webfetch":"allow"}' ;;
      edit) PERM='{"edit":"ask","bash":"ask","webfetch":"allow"}' ;;
      auto) PERM='{"edit":"allow","webfetch":"allow","bash":{"*":"allow","rm *":"ask","rm -*":"ask","sudo *":"ask","git push*":"ask","git reset --hard*":"ask","chmod *":"ask","chown *":"ask","npm publish*":"ask","dd *":"ask"}}' ;;
      full) PERM='{"edit":"allow","bash":"allow","webfetch":"allow"}' ;;
    esac
    if command -v jq >/dev/null; then
      mkdir -p "$KIT_DIR/var"
      OVERLAY="$KIT_DIR/var/opencode-mode-$MODE.json"
      jq --argjson p "$PERM" '. + {permission: $p}' "$KIT_DIR/opencode/opencode.json" > "$OVERLAY"
      export OPENCODE_CONFIG="$OVERLAY"
    else
      echo "⚠ jq not found — launching with base config (default permissions)"
      export OPENCODE_CONFIG="$KIT_DIR/opencode/opencode.json"
    fi
    AGENT_CMD=(opencode)
    [[ "$MODE" == "plan" ]] && AGENT_CMD+=(--agent plan)
    ;;

  claude)
    command -v claude >/dev/null || { echo "install Claude Code first:  npm i -g @anthropic-ai/claude-code"; exit 1; }
    if [[ "${BACKEND:-auto}" == "gateway" || -z "${ANTHROPIC_BASE_URL:-}" ]]; then
      export ANTHROPIC_BASE_URL="http://localhost:4000"
      export ANTHROPIC_AUTH_TOKEN="${GATEWAY_KEY:?GATEWAY_KEY missing in .env — run ./setup.sh}"
      export ANTHROPIC_MODEL="smart" ANTHROPIC_SMALL_FAST_MODEL="cheap"
      export CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1
      echo "→ Claude Code → gateway tiers (default smart; /model to switch)"
    else
      echo "→ Claude Code → flat-rate primary (${ANTHROPIC_MODEL:-?})   (BACKEND=gateway forces tiers)"
    fi
    export ANTHROPIC_API_KEY=""
    # bridge project memory: Claude Code reads CLAUDE.md, not AGENTS.md
    if [[ -f AGENTS.md && ! -f CLAUDE.md ]]; then
      printf '@AGENTS.md\n' > CLAUDE.md
      echo "→ created CLAUDE.md → @AGENTS.md bridge (kept in your repo — commit or delete)"
    fi
    AGENT_CMD=(claude)
    case "$MODE" in
      plan) AGENT_CMD+=(--permission-mode plan) ;;
      edit) AGENT_CMD+=(--permission-mode default) ;;
      auto) AGENT_CMD+=(--permission-mode acceptEdits)
            echo "  tip: Shift+Tab in-session reaches Claude's native 'auto' classifier mode if your account has it" ;;
      full) AGENT_CMD+=(--dangerously-skip-permissions) ;;
    esac
    ;;

  codex)
    command -v codex >/dev/null || { echo "install Codex CLI first:  npm i -g @openai/codex"; exit 1; }
    CODEX_CFG="$HOME/.codex/config.toml"
    # (1) legacy profile layout — Codex >=0.134 rejects [profiles.*] in config.toml
    if grep -qsE '^[[:space:]]*(\[profiles\.|profile[[:space:]]*=)' "$CODEX_CFG"; then
      cat <<'MSG'
✗ ~/.codex/config.toml uses the LEGACY profile layout, which current Codex rejects. Fix once:
    1) DELETE the [profiles.kit] table (and any top-level  profile = "..."  line)
       — keep [model_providers.kit] and [mcp_servers.playwright]
    2) CREATE ~/.codex/kit.config.toml containing exactly:
         model_provider = "kit"
         model = "smart"          # any tier: frontier|smart|mid|long|cheap|overflow
    3) Under [model_providers.kit] ensure:  wire_api = "responses"
       (Codex removed "chat" support in Feb 2026)
  then re-run:  AGENT=codex code-agent
MSG
      exit 1
    fi
    # (2) stale wire protocol — Chat Completions removed from Codex in Feb 2026
    if grep -sA6 '\[model_providers\.kit\]' "$CODEX_CFG" 2>/dev/null | grep -q 'wire_api[[:space:]]*=[[:space:]]*"chat"'; then
      echo '✗ ~/.codex/config.toml: change  wire_api = "chat"  →  wire_api = "responses"  under [model_providers.kit]'
      echo '  (Codex dropped Chat Completions; the gateway serves /v1/responses)'
      exit 1
    fi
    # (3) not wired yet
    if ! grep -qs 'model_providers\.kit' "$CODEX_CFG" || [[ ! -f "$HOME/.codex/kit.config.toml" ]]; then
      cat <<'TOML'
✗ Codex isn't wired to the gateway yet. One-time setup — TWO files:

# ---- ~/.codex/config.toml  (create or append) --------------------------------
[model_providers.kit]
name = "agentic-kit gateway"
base_url = "http://localhost:4000/v1"
env_key = "OPENAI_API_KEY"          # code-agent sets this to your GATEWAY_KEY
wire_api = "responses"               # Codex removed "chat" in Feb 2026

[mcp_servers.playwright]             # browser-testing loop inside Codex
command = "npx"
args = ["-y", "@playwright/mcp@latest"]

# ---- ~/.codex/kit.config.toml  (NEW file — this IS the 'kit' profile) --------
model_provider = "kit"
model = "smart"                      # any tier: frontier|smart|mid|long|cheap|overflow

then re-run:  AGENT=codex code-agent
TOML
      exit 1
    fi
    export OPENAI_API_KEY="${GATEWAY_KEY:?GATEWAY_KEY missing in .env — run ./setup.sh}"
    AGENT_CMD=(codex --profile kit)
    case "$MODE" in
      plan) AGENT_CMD+=(--sandbox read-only) ;;
      edit) ;;   # codex defaults: workspace writes with approvals
      auto) AGENT_CMD+=(--full-auto) ;;
      full) AGENT_CMD+=(--dangerously-bypass-approvals-and-sandbox) ;;
    esac
    ;;

  *) echo "unknown AGENT=$AGENT (use opencode|claude|codex)"; exit 1 ;;
esac

exec "${AGENT_CMD[@]}"
