#!/usr/bin/env bash
# status — is the gateway up, how much of the $10/mo cap is left, which lanes are active.
set -uo pipefail
KIT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
[[ -f "$KIT_DIR/.env" ]] && set -a && . "$KIT_DIR/.env" && set +a

echo "gateway:"
if curl -fsS http://localhost:4000/health/liveliness >/dev/null 2>&1; then
  echo "  ✓ up (http://localhost:4000)"
else
  echo "  ✗ down — run:  docker compose up -d"; exit 0
fi

if [[ -n "${GATEWAY_KEY:-}" ]]; then
  echo "spend (this key):"
  curl -fsS http://localhost:4000/key/info -H "Authorization: Bearer $GATEWAY_KEY" 2>/dev/null \
    | jq -r '"  spend $\(.info.spend // 0) / cap $\(.info.max_budget // "?")  (resets \(.info.budget_duration // "?"))"' \
    2>/dev/null || echo "  (could not read key info)"
fi

echo "active lanes (keys present in .env):"
for pair in "NVIDIA_API_KEY:nvidia" "GEMINI_API_KEY:gemini(free)" "GROQ_API_KEY:groq" \
            "CEREBRAS_API_KEY:cerebras" "OPENROUTER_API_KEY:openrouter" \
            "DEEPSEEK_API_KEY:deepseek(overflow)" "ANTHROPIC_API_KEY:anthropic(frontier)" \
            "OPENAI_API_KEY:openai(frontier)"; do
  var="${pair%%:*}"; label="${pair##*:}"
  [[ -n "${!var:-}" ]] && echo "  ✓ $label"
done

echo "primary:"
if [[ -f "$KIT_DIR/config/primary.env" ]]; then
  grep -E '^export ANTHROPIC_MODEL=' "$KIT_DIR/config/primary.env" | sed 's/export ANTHROPIC_MODEL=/  active model: /'
else
  echo "  none configured (pure-\$0 mode — using gateway free lanes)"
fi
