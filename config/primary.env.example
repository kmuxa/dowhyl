# ============================================================================
#  config/primary.env  — your flat-rate coding PRIMARY (the daily driver)
#  Copy to config/primary.env  (cp config/primary.env.example config/primary.env)
#
#  Switching primary = uncomment ONE block below, re-source, relaunch.
#  All of these speak the Anthropic protocol, so OpenCode uses them directly
#  via these 3 env vars. They are interactive-use-only: do NOT put these keys
#  in .env / the gateway / the nightly jobs.
#
#  Privacy:  [CN] = code leaves for China servers  |  [US/EU/SG] = safer.
#  Keep sensitive repos off [CN] primaries — route those to a no-train API
#  lane instead (ANTHROPIC_API_KEY frontier, or free NVIDIA Build).
# ============================================================================

# ---- 1) GLM Coding Plan  [CN]  (DEFAULT — cheapest, ~90% of daily coding) ---
export ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
export ANTHROPIC_AUTH_TOKEN="paste-your-GLM-coding-key"
export ANTHROPIC_MODEL="glm-5.2"          # glm-5-turbo / glm-4.7 for routine work

# ---- 2) Alibaba / Qwen Coding Plan  [US/EU/SG]  (privacy-safer, multi-model)
#   Same trivial swap; hosted outside China; key starts sk-sp-.
#   ⚠ Lite tier discontinued Mar 2026 — entry is now Pro (~$50/mo), but one sub
#   covers Qwen + Kimi + GLM + MiniMax models. Only worth it for heavy use.
# export ANTHROPIC_BASE_URL="https://coding-intl.dashscope.aliyuncs.com/apps/anthropic"
# export ANTHROPIC_AUTH_TOKEN="paste-your-sk-sp-...-key"
# export ANTHROPIC_MODEL="qwen3.6-plus"   # or qwen3-coder-next / kimi-k2.5 / glm-5 / minimax-m2.5

# ---- 3) MiniMax Coding Plan  [US/EU/SG]  (budget privacy-safer pick) -------
#   Cheapest paid taste of any primary: prepaid credits from $5, no sub needed;
#   overseas plans give ~2.5x the domestic quota.
# export ANTHROPIC_BASE_URL="https://api.minimax.io/anthropic"     # verify exact URL
# export ANTHROPIC_AUTH_TOKEN="paste-your-minimax-key"
# export ANTHROPIC_MODEL="minimax-m3"

# ---- 4) Kimi Code (Moonshot)  [CN]  (long-context king, >200k) -------------
# export ANTHROPIC_BASE_URL="https://api.moonshot.ai/anthropic"
# export ANTHROPIC_AUTH_TOKEN="paste-your-kimi-key"
# export ANTHROPIC_MODEL="kimi-k2.6"

# ---- 5) Cerebras Code  [US]  (fastest inference, $50+) ---------------------
# export ANTHROPIC_BASE_URL="https://api.cerebras.ai/anthropic"    # verify exact URL
# export ANTHROPIC_AUTH_TOKEN="paste-your-cerebras-code-key"
# export ANTHROPIC_MODEL="qwen-3-coder-480b"

# ---- none: pure-$0 mode ----------------------------------------------------
#   Leave everything commented and just use the gateway's free lanes in
#   OpenCode (models: mid / long / cheap). Slower + more quota juggling.
