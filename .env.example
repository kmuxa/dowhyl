# ============================================================================
#  agentic-coding-kit — environment
#  Copy to .env  (cp .env.example .env)  then fill in what you want.
#  You can start with just the two REQUIRED-FREE keys. Everything else is
#  optional and only widens your lanes. Lines you leave blank are simply
#  skipped — the gateway routes around unavailable models automatically.
# ============================================================================

# ---- gateway internals -----------------------------------------------------
# Admin key. If left as this placeholder, ./setup.sh generates a random one.
LITELLM_MASTER_KEY=sk-local-master-change-me
REDIS_HOST=redis
REDIS_PORT=6379
# Postgres backs virtual keys + budgets (needed for the $10 hard cap).
# If you change POSTGRES_PASSWORD, change it in DATABASE_URL too (must match).
POSTGRES_PASSWORD=litellm
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm
# GATEWAY_KEY is generated for you by ./setup.sh (a $10/mo budget-capped key).
GATEWAY_KEY=

# ---- REQUIRED-FREE (no credit card, and they don't train on your code) -----
NVIDIA_API_KEY=          # build.nvidia.com  -> Qwen3-Coder-480B, DeepSeek V4, etc. [no-train]
GEMINI_API_KEY=          # aistudio.google.com -> Gemini 3 Flash / Flash-Lite (free tier)

# ---- OPTIONAL-FREE (widen the mid/cheap lanes; no card) --------------------
GROQ_API_KEY=            # console.groq.com   -> very fast gpt-oss-120b, llama
CEREBRAS_API_KEY=        # cloud.cerebras.ai  -> gpt-oss-120b (~1M tok/day)
OPENROUTER_API_KEY=      # openrouter.ai      -> many :free models; $10 topup -> 1000 req/day
CLOUDFLARE_API_KEY=      # Workers AI 10k neurons/day (also set CLOUDFLARE_ACCOUNT_ID)
CLOUDFLARE_ACCOUNT_ID=
SAMBANOVA_API_KEY=       # cloud.sambanova.ai -> fast llama-405b (free + $5 credit)

# ---- FRONTIER-PAID (pay-as-you-go, capped at $10/mo by the gateway) --------
#   NOTE: the Anthropic API is NOT the $17 Claude chat subscription — it's
#   per-token, ~$5 minimum load. Same for OpenAI. Leave blank to stay $0.
ANTHROPIC_API_KEY=       # console.anthropic.com -> Opus 4.8 / Sonnet 5 (frontier)
OPENAI_API_KEY=          # platform.openai.com   -> GPT-5.5 (frontier)
DEEPSEEK_API_KEY=        # platform.deepseek.com -> V4-Flash $0.14/$0.28 (cheapest overflow)
XAI_API_KEY=             # x.ai -> Grok (often ships monthly free credits; verify)

# ============================================================================
#  The flat-rate PRIMARY (your daily driver) lives in config/primary.env,
#  NOT here — it is used directly by OpenCode, never through this gateway
#  (these plans forbid API/automation use). See config/primary.env.example.
# ============================================================================
